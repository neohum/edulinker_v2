# edulinker 환경 변수 (개발용)

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5200

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=edulinker
DB_PASSWORD=edulinker
DB_NAME=edulinker
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO (교내 파일)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=edulinker-local

# Wasabi S3 (웹·앱 파일)
WASABI_ENDPOINT=s3.ap-northeast-1.wasabisys.com
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_REGION=ap-northeast-1
WASABI_BUCKET=edulinker

# JWT
JWT_SECRET=edulinker-dev-secret-change-me-in-production
